{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/api/dashboard" },
    { "source": "/auth", "destination": "/api/auth" },
    { "source": "/callback", "destination": "/api/callback" },
    { "source": "/aggregate", "destination": "/api/aggregate" },
    { "source": "/admin", "destination": "/api/admin" },
    { "source": "/snapshot", "destination": "/api/snapshot" },
    { "source": "/refresh", "destination": "/api/refresh" },
    { "source": "/connect", "destination": "/api/connect" }
  ],
  "crons": [
    { "path": "/api/refresh", "schedule": "0 8 * * *" },
    { "path": "/api/snapshot", "schedule": "0 9 * * *" }
  ]
}
